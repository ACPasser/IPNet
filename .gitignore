# ===================== 虚拟环境（避免误删/追踪） =====================
# 虚拟环境目录
zhihunet-env/
# 通用虚拟环境命名
venv/
env/
.env
*.env
ENV/

# ===================== Python 编译/缓存文件 =====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/

# ===================== 全局忽略规则 =====================
data/**/*.txt
data/**/*.csv
# ===================== 例外放行规则 =====================
# UCI/IA 仅保留 graph.txt
!data/uci/**/graph.txt
!data/ia/**/graph.txt
# ZHIHU 仅保留 graph.csv
!data/zhihu/**/graph.csv

# ===================== 通用忽略 =====================
# 忽略训练输出目录（检查点/最佳模型/结果）
training_output/
*.pth
*.pt
*.ckpt
*.bin
logs/
*.log
training_logs/
*.tmp
*.temp

# ===================== 系统/编辑器文件 =====================
# Mac 系统
.DS_Store
.AppleDouble
.LSOverride
# Windows 系统
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN
# IDE 配置
.idea/
.vscode/
*.swp
*.swo
.idea_modules/
# Git 无关文件
.gitattributes
.gitignore.local